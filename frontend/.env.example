# TEE backend (default: /api/tee via Vite proxy)
# VITE_TEE_URL=/api/tee

# U2SSO: SSO base URL. When set, enables SSO login + nullifier flow.
# Use /sso-api for Vite proxy → sso-poc-stub (localhost:8081) or real sso-poc
# VITE_SSO_BASE_URL=/sso-api

# Override sso-poc proxy target (default: localhost:8081)
# VITE_SSO_PROXY_TARGET=http://localhost:8081
